{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/dp/Documents/M/gaozhong/scripts/precode_review_hook.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/dp/Documents/M/gaozhong/scripts/user_prompt_continuity_hook.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/dp/Documents/M/gaozhong/scripts/stop_gate.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/dp/Documents/M/gaozhong/scripts/session_start_hook.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
